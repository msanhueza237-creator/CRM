VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_ENV=local

# Edge Function secrets for Gmail API. Do not expose these in frontend code.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GMAIL_SENDER=msanhueza@latinchile.cl
GMAIL_TOKEN_ENCRYPTION_KEY=

# Redirect URI — must be registered in Google Cloud Console > Credentials > OAuth Client > Authorized redirect URIs.
# Local (Supabase CLI):
GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/gmail-integration/callback
# Self-hosted (update host to match your Supabase URL):
# GOOGLE_REDIRECT_URI=http://crm-climactiva-supabase-ff88c0-187-77-53-52.sslip.io/functions/v1/gmail-integration/callback
# Production (Supabase hosted):
# GOOGLE_REDIRECT_URI=https://YOUR-PROJECT.supabase.co/functions/v1/gmail-integration/callback

# CRM frontend URL — used for CORS and OAuth redirects back to the app.
CRM_APP_URL=http://localhost:5173
# Production:
# CRM_APP_URL=https://crm.latinchile.cl
