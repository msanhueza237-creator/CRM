# Configuracion del script scripts/backup-database.sh
# Copiar como "backup-database.env" en el VPS (junto al script) y completar.
# NO subir el archivo real (backup-database.env) al repositorio.

# Nombre exacto del contenedor Docker de Postgres. Averiguarlo en el VPS con:
#   docker ps | grep postgres
POSTGRES_CONTAINER=supabase-db

# Usuario y base de datos de Postgres.
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# Carpeta del VPS donde se guardan los archivos .dump.
BACKUP_DIR=/var/backups/climactiva-crm/db

# Dias de retencion: backups mas viejos que esto se eliminan automaticamente.
RETENTION_DAYS=14
